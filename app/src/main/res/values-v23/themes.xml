<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Go" parent="Theme.MaterialComponents.DayNight.DarkActionBar.Bridge">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/GO_BACKGROUND</item>
        <item name="colorPrimaryVariant">@color/GO_BACKGROUND</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/GO_BACKGROUND</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="ThemeOverlay.SearchView" parent="">
        <item name="android:color">@color/black</item>
    </style>
</resources>